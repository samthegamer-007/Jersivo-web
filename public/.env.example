# Jersivo Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Sheets Spreadsheet IDs
# Get these from your Google Sheets URLs after creating the spreadsheets
# Example URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
GOOGLE_SHEET_ID_PRODUCTS=your_products_spreadsheet_id_here
GOOGLE_SHEET_ID_CREDENTIALS=your_credentials_spreadsheet_id_here
GOOGLE_SHEET_ID_LOGS=your_logs_spreadsheet_id_here

# Google Service Account (path to JSON file)
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# Session Secret (generate a random long string)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_string_here_minimum_32_characters

# Server Port (optional, Render sets this automatically)
PORT=3000

# Node Environment
NODE_ENV=development